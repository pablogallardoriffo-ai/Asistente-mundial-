# Configura estas variables en Vercel → Settings → Environment Variables
# (NO subas tu clave real al repositorio).

# Obligatoria: tu clave de API-Football (https://dashboard.api-football.com/)
FOOTBALL_API_KEY=tu_clave_aqui

# Opcionales: temporadas y ligas (por defecto Mundial=1, Chile=265).
# OJO: el plan gratis suele permitir solo temporadas 2021-2023.
APIFB_WC_SEASON=2026
APIFB_CHILE_SEASON=2025
APIFB_WC_LEAGUE=1
APIFB_CHILE_LEAGUE=265
